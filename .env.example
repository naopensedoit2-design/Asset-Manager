# ─── Database ────────────────────────────────────────────────
# Neon PostgreSQL connection string (or any PostgreSQL-compatible URL)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# ─── Cloudinary ──────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"

# ─── Admin Authentication ────────────────────────────────────
# bcrypt hash of the admin password. Generate with:
#   node -e "const b=require('bcrypt');b.hash('yourpassword',12).then(console.log)"
ADMIN_PASSWORD_HASH="$2b$12$..."

# ─── Session ─────────────────────────────────────────────────
# Strong random string for signing cookies
SESSION_SECRET="change_me_to_a_long_random_string"

# ─── WhatsApp ────────────────────────────────────────────────
# Phone number with country code, no spaces or symbols (e.g. 5554999999999)
WHATSAPP_NUMBER="5554999999999"
