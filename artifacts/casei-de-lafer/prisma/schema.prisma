generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model HeroImage {
  id        Int      @id @default(autoincrement())
  type      String
  url       String
  publicId  String   @default("")
  videoUrl  String   @default("")
  updatedAt DateTime @updatedAt
}

model GalleryImage {
  id        Int      @id @default(autoincrement())
  url       String
  publicId  String   @default("")
  alt       String   @default("")
  coupleTag String   @default("")
  location  String   @default("")
  createdAt DateTime @default(now())
}

model BlockedDate {
  id    Int      @id @default(autoincrement())
  date  DateTime
  label String   @default("Reservado")
}

model SiteConfig {
  id             Int      @id @default(autoincrement())
  whatsappNumber String   @default("")
  weddingCount   Int      @default(0)
  driverQuote    String   @default("")
  showCalendar   Boolean  @default(true)
}
